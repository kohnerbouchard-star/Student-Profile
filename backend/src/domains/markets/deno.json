{
  "fmt": {
    "lineWidth": 160,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "operatorPosition": "maintain",
    "bracePosition": "maintain",
    "nextControlFlowPosition": "maintain",
    "singleBodyPosition": "maintain",
    "sortNamedImports": "maintain",
    "sortNamedExports": "maintain",
    "quoteProps": "preserve"
  }
}

{
  "name": "econovaria-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "smoke": "npm run test:smoke",
    "test:smoke": "npm run test:player-market-assets && SUPABASE_URL=http://localhost:54321 SUPABASE_ANON_KEY=smoke-anon-key SUPABASE_SERVICE_ROLE_KEY=smoke-service-role-key deno run --config=supabase/functions/deno.json --allow-env=SUPABASE_URL,SUPABASE_ANON_KEY,SUPABASE_SERVICE_ROLE_KEY --deny-net --lock=supabase/functions/deno.lock --frozen src/smoke/classroomApiSmokeTest.ts && npm run test:player-request-scope && npm run test:player-world && npm run test:player-inventory && npm run test:admin-api",
    "test:player-request-scope": "deno test --config supabase/functions/classroom-api/deno.json --lock=supabase/functions/deno.lock --frozen src/domains/players/api/playerRequestScope.test.ts",
    "test:player-world": "deno test --config supabase/functions/classroom-api/deno.json --lock=supabase/functions/deno.lock --frozen src/domains/countries/api/playerWorldRoutePaths.test.ts src/domains/countries/api/playerWorldRequestParser.test.ts src/domains/countries/api/playerWorldReadHttpHandler.test.ts src/domains/countries/services/playerWorldReadService.test.ts src/domains/countries/infrastructure/supabasePlayerWorldReadRepository.test.ts",
    "test:player-inventory": "deno test --config supabase/functions/classroom-api/deno.json --lock=supabase/functions/deno.lock --frozen src/domains/inventory/api/playerInventoryRoutePaths.test.ts src/domains/inventory/api/playerInventoryRequestParser.test.ts src/domains/inventory/api/playerInventoryReadHttpHandler.test.ts src/domains/inventory/services/playerInventoryReadService.test.ts src/domains/inventory/infrastructure/supabasePlayerInventoryReadRepository.test.ts",
    "test:player-market-assets": "deno test --config supabase/functions/classroom-api/deno.json --lock=supabase/functions/deno.lock --frozen src/domains/stocks/api/playerStockAssetListRoutePaths.test.ts src/domains/stocks/api/playerStockAssetListRequestParser.test.ts src/domains/stocks/api/playerStockAssetListHttpHandler.test.ts src/domains/stocks/api/playerStockAssetDetailRequestParser.test.ts src/domains/stocks/api/playerStockAssetDetailHttpHandler.test.ts src/domains/stocks/api/playerStockWatchlistRoutePaths.test.ts src/domains/stocks/api/playerStockWatchlistRequestParser.test.ts src/domains/stocks/api/playerStockWatchlistHttpHandler.test.ts src/domains/stocks/services/playerStockAssetListService.test.ts src/domains/stocks/services/playerStockAssetDetailService.test.ts src/domains/stocks/services/playerStockWatchlistService.test.ts src/domains/stocks/infrastructure/supabasePlayerStockAssetListRepository.test.ts src/domains/stocks/infrastructure/supabasePlayerStockAssetDetailRepository.test.ts src/domains/stocks/infrastructure/supabasePlayerStockWatchlistRepository.test.ts",
    "test:admin-api": "deno test --config supabase/functions/admin-api/deno.json --lock=supabase/functions/deno.lock --frozen supabase/functions/admin-api/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:edge": "deno check --config supabase/functions/classroom-api/deno.json --lock=supabase/functions/deno.lock --frozen supabase/functions/classroom-api/index.ts",
    "typecheck:stock-edge": "deno check --config=supabase/functions/deno.json --lock=supabase/functions/deno.lock --frozen supabase/functions/stock-market-player-read/index.ts supabase/functions/stock-market-read/index.ts supabase/functions/stock-market-runner/index.ts supabase/functions/stock-market-seed-copy/index.ts supabase/functions/stock-market-trading/index.ts",
    "typecheck:admin-edge": "deno check --config supabase/functions/admin-api/deno.json --lock=supabase/functions/deno.lock --frozen supabase/functions/admin-api/index.ts",
    "typecheck:all": "npm run typecheck && npm run typecheck:edge && npm run typecheck:stock-edge && npm run typecheck:admin-edge"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}

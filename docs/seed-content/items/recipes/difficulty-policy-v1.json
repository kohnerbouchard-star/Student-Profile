    "insane"
  ],
  "legacyAlias": {
    "standard": "moderate"
  },
  "principles": [
    "Difficulty is game-session scoped and versioned.",
    "Resolved recipes are snapshotted when a crafting quote is accepted.",
    "Active jobs are never rewritten by a later difficulty change.",
    "Output quantity and equipment effect power never scale with difficulty.",
    "Identity-defining and strategic ingredients never scale.",
    "Only recipe roles explicitly marked elastic_common or elastic_energy scale.",
    "Crafting remains deterministic and has no hidden failure roll."
  ],
  "ingredientScaling": {
    "fixed_identity": {
      "easy": 1.0,

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://econovaria.invalid/schemas/release-manifest.schema.json",
  "title": "Econovaria immutable release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseId",
    "generatedAt",
    "source",
    "migrations",
    "configuration",
    "artifacts",
    "artifactSetSha256",
    "provenance",
    "environmentNeutrality",
    "promotionPolicy"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "releaseId": { "type": "string", "minLength": 16 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "ref", "commit", "mergedIntoMain"],
      "properties": {
        "repository": { "const": "kohnerbouchard-star/Student-Profile" },
        "ref": { "const": "refs/heads/main" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "mergedIntoMain": { "const": true }
      }
    },
    "migrations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "count", "versionSetSha256"],
      "properties": {
        "head": { "type": ["string", "null"], "pattern": "^[0-9]{14}$" },
        "count": { "type": "integer", "minimum": 0 },
        "versionSetSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "version", "featureFlags", "file", "sha256"],
      "properties": {
        "schemaVersion": { "type": "integer", "minimum": 1 },
        "version": { "type": "string", "minLength": 6 },
        "featureFlags": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "boolean" }
        },
        "file": { "const": "release-configuration.json" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["kind", "file", "sha256", "sizeBytes"],
        "properties": {
          "kind": { "enum": ["frontend", "edge-function"] },
          "name": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "pattern": "^artifacts/[a-zA-Z0-9._-]+\\.tar\\.gz$" },
          "sha256": { "$ref": "#/$defs/sha256" },
          "sizeBytes": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "artifactSetSha256": { "$ref": "#/$defs/sha256" },
    "provenance": {
      "type": "object",
      "required": ["builder", "workflow", "workflowRunId", "workflowRunAttempt", "repository", "sourceCommit", "deterministicArchive"],
      "properties": {
        "builder": { "const": "github-actions" },
        "workflow": { "type": "string" },
        "workflowRunId": { "type": "string" },
        "workflowRunAttempt": { "type": "string" },
        "repository": { "const": "kohnerbouchard-star/Student-Profile" },
        "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "deterministicArchive": { "const": "gnu-tar+gzip-n" }
      }
    },
    "environmentNeutrality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "verifier",
        "scannedRoots",
        "auditedProductionProjectRefSha256",
        "auditedWorkerOriginSha256"
      ],
      "properties": {
        "status": { "const": "pass" },
        "verifier": { "const": "release-environment-neutrality-v1" },
        "scannedRoots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "auditedProductionProjectRefSha256": {
          "anyOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "auditedWorkerOriginSha256": {
          "anyOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        }
      }
    },
    "promotionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rebuildAllowed", "requiredSequence", "identity"],
      "properties": {
        "rebuildAllowed": { "const": false },
        "requiredSequence": { "const": ["staging", "production"] },
        "identity": { "const": "artifactSetSha256" }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}

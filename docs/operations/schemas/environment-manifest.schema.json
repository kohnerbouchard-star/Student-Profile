{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://econovaria.invalid/schemas/environment-manifest.schema.json",
  "title": "Econovaria environment manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "environment",
    "githubEnvironment",
    "identity",
    "dataPolicy",
    "frontend",
    "supabase",
    "secretNames"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "environment": { "enum": ["development", "staging", "production"] },
    "githubEnvironment": { "enum": ["development", "staging", "production"] },
    "identity": { "type": "string", "minLength": 6 },
    "dataPolicy": { "enum": ["synthetic-only", "production-controlled"] },
    "frontend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "identity"],
      "properties": {
        "provider": { "type": "string", "minLength": 2 },
        "identity": { "type": "string", "minLength": 6 }
      }
    },
    "supabase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organization", "projectRef"],
      "properties": {
        "organization": { "type": "string", "minLength": 2 },
        "projectRef": { "type": "string", "minLength": 6 }
      }
    },
    "secretNames": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" }
    }
  }
}

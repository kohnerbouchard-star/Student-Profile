    "audit:seed-content-active-candidates": "node scripts/generate-remaining-active-market-candidates.mjs --check",
    "audit:seed-content-arrivals": "node scripts/generate-arrival-foundation-content.mjs --check",
    "audit:seed-content-canonicalization": "node scripts/apply-seed-market-canonicalization.mjs --check",
    "audit:seed-content-core-gameplay": "node scripts/generate-core-gameplay-content.mjs --check",
    "audit:seed-content-core-coverage": "node scripts/seed-core-content-coverage-audit.mjs --check",
    "audit:seed-content-editorial": "node scripts/seed-content-universe-editorial-audit.mjs --check",
    "audit:seed-content-exchanges": "node scripts/seed-exchange-calendar-audit.mjs",
    "audit:seed-content-financial": "node scripts/seed-content-solvend-financial-audit.mjs",
    "audit:seed-content-identities": "node scripts/seed-market-identity-reconciliation-summary.mjs --check",
    "audit:seed-content-issuers": "node scripts/seed-content-issuer-audit.mjs",
    "audit:seed-content-simulation-policy": "node scripts/apply-seed-simulation-retention-policy.mjs --check",
    "audit:seed-content-simulations": "node scripts/build-northreach-simulation-input.mjs --check && node scripts/reconcile-seed-simulation-evidence.mjs --check",
    "audit:seed-content-universe": "node scripts/generate-seed-market-universe.mjs --check",
    "build:seed-content-northreach-input": "node scripts/build-northreach-simulation-input.mjs",
    "preflight:seed-content": "node scripts/seed-content-preflight.mjs --environment test --mode design",
    "preflight:seed-content:staging": "node scripts/seed-beta-staging-preflight.mjs",
    "test:seed-content-preflight": "node --test scripts/seed-content-preflight.test.mjs",
    "build:seed-beta-pack": "node scripts/build-seed-beta-pack.mjs && node scripts/build-seed-beta-calibration.mjs",
    "validate:seed-beta-pack": "node scripts/seed-beta-pack-validator.mjs",
    "test:seed-beta-pack": "node --test scripts/seed-beta-pack.test.mjs scripts/seed-beta-consumer-contract.test.mjs",
    "test:seed-beta-release-db": "node scripts/seed-beta-transactional-release-probe.mjs",
    "seed:beta:validate": "node scripts/seed-beta-importer.mjs --mode validate --environment test",
    "seed:beta:dry-run": "node scripts/seed-beta-importer.mjs --mode dry-run --environment staging",
    "build:physical-economy-pack": "node scripts/build-physical-economy-runtime-pack.mjs",
    "simulate:physical-economy": "node scripts/simulate-physical-economy-balance.mjs",
    "test:crafting-runtime": "node --test scripts/crafting-runtime-contract.test.mjs scripts/crafting-admin-replay-contract.test.mjs scripts/crafting-branch-hygiene.test.mjs scripts/crafting-pack-version-identity-contract.test.mjs scripts/crafting-seed-definition-boundary.test.mjs scripts/crafting-salvage-calibration-contract.test.mjs scripts/crafting-scarcity-projection-contract.test.mjs scripts/lib/physical-economy-pack-contract.test.mjs && node scripts/admin-crafting-oversight-contract.mjs"
  },
  "devDependencies": {
    "playwright": "1.61.1",
    "supabase": "2.109.1"
  }
}
